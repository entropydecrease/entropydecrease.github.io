    <item>
      <title>随手记：2024奥运观赛</title>
      <link>https://entropydecrease.github.io/posts/%E9%9A%8F%E6%89%8B%E8%AE%B02024%E5%A5%A5%E8%BF%90%E8%A7%82%E8%B5%9B/</link>
